{
    "extends": "astro/tsconfigs/strict",
    "compilerOptions": {
        "strictNullChecks": true,
        "paths": {
            "@components/*": ["./src/components/*"],
            "@layouts/*": ["./src/layouts/*"],
            "@lib/*": ["./src/lib/*"],
            "@consts": ["./src/consts.ts"],
            "@types": ["./src/types.ts"]
        },
        "jsx": "react-jsx",
        "jsxImportSource": "react"
    }
}
