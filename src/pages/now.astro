---
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import Link from "@components/Link.astro";
import LinkEnhancer from "@components/LinkEnhancer.astro";
import { NOW, SITE } from "@consts";
import PageLayout from "@layouts/PageLayout.astro";
import { frontmatter } from "../content/now.md";

type NowItem = {
    item: string;
    href?: string;
};

type NowFrontmatter = {
    updated?: string;
    current?: NowItem[];
    reading?: NowItem[];
    watching?: NowItem[];
};

const nowFrontmatter = frontmatter as NowFrontmatter;
const currentItems = nowFrontmatter.current ?? [];
const mediaSections = [
    { title: "最近在读", icon: "book", items: nowFrontmatter.reading ?? [] },
    { title: "最近在看", icon: "screen", items: nowFrontmatter.watching ?? [] },
].filter((section) => section.items.length > 0);
---

<PageLayout title={`${NOW.TITLE} | ${SITE.NAME}`} description={NOW.DESCRIPTION} lang="en">
    <Container>
        <section class="space-y-10 sm:space-y-12">
            <div class="animate max-w-2xl space-y-2">
                <h1
                    class="serif-reading-title text-3xl font-bold tracking-[0.01em] text-[var(--site-color-text-primary)] sm:text-4xl"
                >
                    Now
                </h1>

                {nowFrontmatter.updated && (
                    <p class="text-sm text-[var(--site-color-text-muted)]">
                        Last updated
                        <span class="font-medium text-[var(--site-color-text-heading)]">
                            <FormattedDate date={new Date(nowFrontmatter.updated)} />
                        </span>
                    </p>
                )}
            </div>

            {currentItems.length > 0 && (
                <section class="animate space-y-4">
                    <h2
                        class="serif-reading-title text-2xl font-bold text-[var(--site-color-text-primary)]"
                    >
                        近况
                    </h2>

                    <ul class="serif-reading-surface site-prose-links list-disc space-y-2 pl-5 text-[1rem] leading-7 text-[var(--site-color-text-body)]">
                        {currentItems.map((item) => (
                            <li>
                                {item.href ? (
                                    <Link href={item.href} external={true} underline={true}>
                                        {item.item}
                                    </Link>
                                ) : (
                                    item.item
                                )}
                            </li>
                        ))}
                    </ul>
                </section>
            )}

            {mediaSections.length > 0 && (
                <section class="animate space-y-4">
                    <h2
                        class="serif-reading-title text-2xl font-bold text-[var(--site-color-text-primary)]"
                    >
                        书影音游
                    </h2>

                    <div class="space-y-6">
                        {mediaSections.map((section) => (
                            <section class="space-y-3">
                                <h3 class="flex items-center gap-2 serif-reading-title text-lg font-semibold text-[var(--site-color-text-heading)]">
                                    <span aria-hidden="true" class="shrink-0 text-[1.05rem] leading-none">
                                        {section.icon === "book" ? "📚" : "🎬"}
                                    </span>
                                    <span>{section.title}</span>
                                </h3>

                                <ul class="serif-reading-surface site-prose-links list-disc space-y-2 pl-5 text-[1rem] leading-7 text-[var(--site-color-text-body)]">
                                    {section.items.map((item) => (
                                        <li>
                                            {item.href ? (
                                                <Link
                                                    href={item.href}
                                                    external={true}
                                                    underline={true}
                                                >
                                                    {item.item}
                                                </Link>
                                            ) : (
                                                item.item
                                            )}
                                        </li>
                                    ))}
                                </ul>
                            </section>
                        ))}
                    </div>
                </section>
            )}
        </section>
    </Container>

    <LinkEnhancer />
</PageLayout>
