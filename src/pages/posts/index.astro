---
import ArrowCard from "@components/ArrowCard.astro";
import Container from "@components/Container.astro";
import { BLOG, SITE } from "@consts";
import PageLayout from "@layouts/PageLayout.astro";
import { getPublishedPosts, groupPostsByYear } from "@lib/posts";

const posts = groupPostsByYear(await getPublishedPosts());
const years = Object.keys(posts).sort((a, b) => Number.parseInt(b, 10) - Number.parseInt(a, 10));
---

<PageLayout title={`${BLOG.TITLE} | ${SITE.NAME}`} description={BLOG.DESCRIPTION} lang="en">
    <Container>
        <div class="space-y-12 sm:space-y-16">
            <div class="space-y-10 sm:space-y-14">
                {years.map((year) => (
                        <section class="animate space-y-4 sm:space-y-5">
                            <div class="serif-reading-title text-[1.36rem] font-semibold leading-none text-[var(--site-color-text-heading)] sm:text-[1.8rem]">
                                {year}
                            </div>
                            <div>
                                <ul class="flex flex-col gap-1.5">
                                    {posts[year].map((post) => (
                                        <li>
                                            <ArrowCard entry={post} variant="archive" />
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        </section>
                    ))}
            </div>
        </div>
    </Container>
</PageLayout>
