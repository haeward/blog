---
import { Image } from "astro:assets";
import ArrowCard from "@components/ArrowCard.astro";
import Container from "@components/Container.astro";
import { SITE, SOCIALS } from "@consts";
import PageLayout from "@layouts/PageLayout.astro";
import { getPageOg } from "@lib/og";
import { getRecentPosts } from "@lib/posts";

const blog = await getRecentPosts(SITE.NUM_POSTS_ON_HOMEPAGE);
const pageOg = getPageOg("home");
---

<PageLayout
    title={SITE.NAME}
    description={SITE.DESC}
    ogImage={pageOg.ogImage}
    ogImageAlt={pageOg.ogImageAlt}
    lang="en"
>
    <Container>
        <div class="space-y-12 sm:space-y-14">
            <section>
                <div class="flex justify-center items-center mb-4">
                    <div class="relative w-48 h-48">
                        <Image
                            src="/assets/images/site/home-hover-runtime.webp"
                            alt="programmer"
                            class="w-full h-full animate"
                            width={192}
                            height={192}
                            loading="eager"
                        />
                    </div>
                </div>
                <div class="flex justify-center animate gap-4 mb-4">
                    {SOCIALS.filter(social => social.ENABLE !== false).map((social) => (
            <a
              href={social.HREF}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-[var(--site-color-text-neutral-hover)] transition-colors duration-300"
              aria-label={social.NAME}
            >
              <Image
                src={social.ICON}
                alt={social.NAME}
                class="w-7 h-7"
                width={28}
                height={28}
                loading="eager"
              />
            </a>
          ))}
                </div>
            </section>

            <section class="animate px-1 py-2 sm:px-0 sm:py-3">
                <div class="mb-5">
                    <h1
                        class="serif-reading-title text-[1rem] font-semibold tracking-[0.2em] text-[var(--site-color-text-heading)] uppercase sm:text-[1.12rem]"
                    >
                        LATEST POSTS
                    </h1>
                </div>
                <ul class="flex flex-col gap-1.5">
                    {blog.map(post => (
            <li>
              <ArrowCard entry={post} variant="home" />
            </li>
          ))}
                </ul>
            </section>
        </div>
    </Container>
</PageLayout>
