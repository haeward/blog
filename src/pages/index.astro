---

<PageLayout title={SITE.NAME} description={SITE.DESC}>
  <Container>
    <!-- <h4 class="animate font-semibold text-black dark:text-white">
      Hi, I'm Nano <span class="text-xl">👋🏻</span> 
    </h4> -->
    <div class="space-y-16">
      <section>
        <div class="flex justify-center items-center mb-4">
          <div class="relative w-48 h-48">
            <img src="/programmer-light.svg" class="w-full h-full animate light-only absolute top-0 left-0" />
            <img src="/programmer-dark.svg" class="w-full h-full animate dark-only hidden absolute top-0 left-0" />
          </div>
        </div>
        <div class="flex justify-center gap-4 mb-4">
          {SOCIALS.filter(social => social.ENABLE !== false).map((social) => (
            <a 
              href={social.HREF} 
              target="_blank" 
              rel="noopener noreferrer"
              class="hover:text-black dark:hover:text-white transition-colors duration-300"
              aria-label={social.NAME}
              title={social.NAME}
            >
              <img 
                src={social.ICON}
                alt={social.NAME}
                class="w-6 h-6"
              />
            </a>
          ))}
        </div>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h3 class="font-semibold text-black dark:text-white text-lg">
            Latest posts
          </h3>
          <Link href="/blog">
            See all posts
          </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {blog.map(post => (
            <li>
              <ArrowCard entry={post} />
            </li>
          ))}
        </ul>
      </section>

      <!-- <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Work Experience
          </h5>
          <Link href="/work">
            See all work
          </Link>
        </div>
        <ul class="flex flex-col space-y-4">
          {work.map(entry => (
            <li>
              <div class="text-sm opacity-75">
