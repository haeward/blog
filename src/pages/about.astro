---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import LinkEnhancer from "@components/LinkEnhancer.astro";
import { SITE, ABOUT } from "@consts";
import { Content as AboutContent } from "../content/about.md";
---

<PageLayout title={`${ABOUT.TITLE} | ${SITE.NAME}`} description={ABOUT.DESCRIPTION} lang="en">
  <Container>
    <div class="space-y-8">
      <article class="animate serif-reading-surface prose dark:prose-invert max-w-none" data-language-scan="true" lang="en">
        <AboutContent />
      </article>
    </div>
  </Container>

  <LinkEnhancer />
</PageLayout>
