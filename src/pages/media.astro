---
import Container from "@components/Container.astro";
import MediaBrowser from "@components/MediaBrowser.astro";
import { MEDIA, SITE } from "@consts";
import PageLayout from "@layouts/PageLayout.astro";
import { getMediaPageData } from "@lib/media";

const { tabs, defaultItems, manifest } = getMediaPageData();
---

<PageLayout title={`${MEDIA.TITLE} | ${SITE.NAME}`} description={MEDIA.DESCRIPTION}>
    <Container>
        <MediaBrowser tabs={tabs} defaultItems={defaultItems} manifest={manifest} />
    </Container>
</PageLayout>
