---
import Container from "@components/Container.astro";
import MediaBrowser from "@components/MediaBrowser.astro";
import { MEDIA, SITE } from "@consts";
import PageLayout from "@layouts/PageLayout.astro";
import { getMediaPageData } from "@lib/media";

const { tabs, defaultItems, serializedItemsByTab } = getMediaPageData();
---

<PageLayout title={`${MEDIA.TITLE} | ${SITE.NAME}`} description={MEDIA.DESCRIPTION}>
    <Container>
        <MediaBrowser
            tabs={tabs}
            defaultItems={defaultItems}
            serializedItemsByTab={serializedItemsByTab}
        />
    </Container>
</PageLayout>
