---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { NOW } from "@consts";

const nowEntries = await getCollection("now");
const nowEntry = nowEntries.find(entry => entry.id === "now.md") || nowEntries[0];
const { Content } = await nowEntry.render();
---

<PageLayout title={NOW.TITLE} description={NOW.DESCRIPTION}>
  <Container>
    <div class="space-y-6">
      <h1 class="animate font-semibold text-xl text-black dark:text-white">
        {nowEntry.data.title}
      </h1>
      <div class="animate text-sm text-black/60 dark:text-white/60">
        Last updated: {nowEntry.data.updated.toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric"
        })}
      </div>
      <article class="animate prose dark:prose-invert mt-10">
        <Content />
      </article>
    </div>
  </Container>
</PageLayout>
