---
import Container from "@components/Container.astro";
import LinkEnhancer from "@components/LinkEnhancer.astro";
import { SITE, TOOLBOX } from "@consts";
import PageLayout from "@layouts/PageLayout.astro";
import { Content as ToolboxContent } from "../content/toolbox.md";
---

<PageLayout title={`${TOOLBOX.TITLE} | ${SITE.NAME}`} description={TOOLBOX.DESCRIPTION} lang="en">
    <Container>
        <section class="toolbox-page space-y-6 sm:space-y-8">
            <div class="animate max-w-2xl space-y-3">
                <h1
                    class="serif-reading-title text-3xl font-bold tracking-[0.01em] text-[var(--site-color-text-primary)] sm:text-4xl"
                >
                    Toolbox
                </h1>
            </div>

            <article
                class="animate toolbox-content serif-reading-surface site-prose-links prose dark:prose-invert max-w-none"
            >
                <ToolboxContent />
            </article>
        </section>
    </Container>

    <LinkEnhancer />
</PageLayout>
