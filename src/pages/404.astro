---
import Container from "@components/Container.astro";
import { SITE } from "@consts";
import PageLayout from "@layouts/PageLayout.astro";
---

<PageLayout
    title={`404 | ${SITE.NAME}`}
    description="The page you are looking for does not exist or has moved."
>
    <Container>
        <div class="flex flex-col items-center justify-center h-[60vh] text-center px-4">
            <h1
                class="text-7xl sm:text-9xl font-bold text-[var(--site-color-text-primary)] transition-colors"
            >
                404
            </h1>
            <p class="text-xl mb-4 text-[var(--site-color-text-heading)]">Oops! Page not found</p>
            <p class="text-lg mb-8 text-[var(--site-color-text-muted)]">
                The page you're looking for doesn't exist or has been moved.
            </p>
            <a
                href="/"
                class="px-6 py-2 border border-current rounded text-[var(--site-color-text-muted)] hover:bg-black/5 hover:text-[var(--site-color-text-neutral-hover)] dark:hover:bg-white/8 transition-colors"
            >
                Go Home
            </a>
        </div>
    </Container>
</PageLayout>

<style>
div {
    padding-bottom: 4rem;
}
h1 {
    margin: 0;
    line-height: 1;
}
</style>
