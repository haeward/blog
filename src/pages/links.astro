---
import Container from "@components/Container.astro";
import LinkCard from "@components/LinkCard.astro";
import { LINKS, SITE } from "@consts";
import PageLayout from "@layouts/PageLayout.astro";
import type { LinkEntry } from "@types";
import { BLOGROLL_LINKS, PODCAST_LINKS, VIDEO_LINKS } from "../data/links";

type LinkSection = {
    key: string;
    title: string;
    items: LinkEntry[];
};

const sections: LinkSection[] = [
    {
        key: "blogroll",
        title: "Blogroll",
        items: BLOGROLL_LINKS,
    },
    {
        key: "videos",
        title: "Videos",
        items: VIDEO_LINKS,
    },
    {
        key: "podcasts",
        title: "Podcast",
        items: PODCAST_LINKS,
    },
];
---

<PageLayout title={`${LINKS.TITLE} | ${SITE.NAME}`} description={LINKS.DESCRIPTION} lang="en">
    <Container>
        <section class="space-y-6 sm:space-y-8">
            <div class="animate space-y-3">
                <h1
                    class="serif-reading-title text-3xl font-bold tracking-[0.01em] text-[var(--site-color-text-primary)] sm:text-4xl"
                >
                    Links
                </h1>
                <p
                    class="serif-reading-surface text-[1.03rem] leading-8 font-medium tracking-[0.014em] text-[var(--site-color-text-body)]"
                >
                    记录一些喜欢的内容。
                </p>
            </div>

            <div class="space-y-9 sm:space-y-10">
                {sections.map((section) => (
                    <section
                        class="animate space-y-5 sm:space-y-6"
                        aria-labelledby={`links-section-${section.key}`}
                        data-links-section={section.key}
                    >
                        <h2
                            id={`links-section-${section.key}`}
                            class="serif-reading-title text-xl font-bold tracking-[0.01em] text-[var(--site-color-text-heading)] sm:text-2xl"
                        >
                            {section.title}
                        </h2>

                        <ul class="mx-auto grid w-full max-w-[40.75rem] grid-cols-1 gap-x-7 gap-y-6 sm:grid-cols-2 md:grid-cols-3">
                            {section.items.map((item) => (
                                <LinkCard item={item} />
                            ))}
                        </ul>
                    </section>
                ))}
            </div>
        </section>
    </Container>
</PageLayout>
