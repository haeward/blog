---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import LinkEnhancer from "@components/LinkEnhancer.astro";
import { SITE, BLOGROLL } from "@consts";
import { Content as BlogrollContent } from "../content/blogroll.md";
---

<PageLayout title={`${BLOGROLL.TITLE} | ${SITE.NAME}`} description={BLOGROLL.DESCRIPTION} lang="en">
  <Container>
    <div class="space-y-8">
      <article class="animate serif-reading-surface prose dark:prose-invert max-w-none" data-language-scan="true" lang="en">
        <BlogrollContent />
      </article>
    </div>
  </Container>

  <LinkEnhancer />
</PageLayout>
