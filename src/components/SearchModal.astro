<div id="site-search" class="site-search" hidden aria-hidden="true" data-search-state="idle">
    <div class="site-search__backdrop" data-search-close="true"></div>

    <section
        class="site-search__panel"
        role="dialog"
        aria-modal="true"
        aria-labelledby="site-search-title"
    >
        <h2 id="site-search-title" class="sr-only">Search articles</h2>

        <div class="site-search__top">
            <label class="site-search__input-shell" for="site-search-input">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="site-search__input-icon"
                    aria-hidden="true"
                >
                    <circle cx="11" cy="11" r="7"></circle>
                    <path d="m20 20-3.5-3.5"></path>
                </svg>
                <input
                    id="site-search-input"
                    class="site-search__input"
                    type="search"
                    placeholder="Search articles..."
                    autocomplete="off"
                    autocapitalize="off"
                    spellcheck="false"
                    enterkeyhint="search"
                >
            </label>

            <button
                type="button"
                class="site-search__close"
                data-search-close="true"
                aria-label="Close search"
            >
                ESC
            </button>
        </div>

        <div class="site-search__divider"></div>

        <div class="site-search__body">
            <p
                id="site-search-summary"
                class="site-search__summary"
                hidden
                role="status"
                aria-live="polite"
            ></p>
            <div id="site-search-content" class="site-search__content"></div>
        </div>

        <div class="site-search__divider"></div>

        <div class="site-search__footer">
            <div class="site-search__hints" aria-hidden="true">
                <span class="site-search__hint"><kbd>Enter</kbd> Open</span>
                <span class="site-search__hint"><kbd>Tab</kbd> Navigate</span>
                <span class="site-search__hint"><kbd>Esc</kbd> Close</span>
            </div>
            <a
                class="site-search__credit"
                href="https://pagefind.app/"
                target="_blank"
                rel="noreferrer noopener"
            >
                Powered by <span>Pagefind</span>
            </a>
        </div>
    </section>
</div>

<script>
import "../scripts/search-modal";
</script>
