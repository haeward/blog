---
import Container from "@components/Container.astro";
import { SITE } from "@consts";
import BackToTop from "@components/BackToTop.astro";
import YearProgress from "@components/YearProgress.astro";

const currentYear = new Date().getFullYear();
---

<footer class="animate">
  <Container>
    <div class="relative mb-4 sm:mb-0">
      <div class="flex justify-end sm:absolute sm:right-0 sm:-top-20">
        <BackToTop />
      </div>
    </div>

    <YearProgress />

    <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
      <div class="animate leading-relaxed">
        <a href="/" class="font-bold text-stone-800 dark:text-stone-300">{SITE.NAME}</a>
        {" | "}
        &copy; 2024 ~ {currentYear}
        {" · "}
        <a href="/rss.xml" class="font-bold text-cyan-600 dark:text-cyan-300 underline">RSS</a>
      </div>
      <div class="animate leading-relaxed sm:text-right">
        Power by{" "}
        <a href="https://astro.build/" class="font-bold text-base text-emerald-700 dark:text-emerald-200">Astro</a>
        {" & "}
        <a href="https://github.com/markhorn-dev/astro-nano" class="font-bold text-base text-emerald-700 dark:text-emerald-200">Astro Nano</a>
      </div>
    </div>
  </Container>
</footer>
