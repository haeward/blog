---

<footer class="animate">
    <Container>
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
            <div
                class="animate flex flex-wrap items-center gap-x-2 gap-y-1 leading-relaxed text-[var(--site-color-text-muted)]"
            >
                <a href="/" class="font-bold">{SITE.NAME}</a>
                <span>|</span>
                <span>&copy; 2024 ~ {currentYear}</span>
                <span>·</span>
                <a
                    href="https://creativecommons.org/licenses/by-nc-sa/4.0/"
                    class="inline-flex items-center gap-1.5 transition-opacity hover:opacity-80"
                    aria-label="CC BY-NC-SA 4.0"
                    rel="license noopener noreferrer"
                    target="_blank"
                >
                    <span>CC BY-NC-SA 4.0</span>
                    <span class="inline-flex items-center gap-1" aria-hidden="true">
                        {ccIcons.map((path) => (
                            <svg
                                class="h-4 w-4"
                                aria-hidden="true"
                                viewBox="0 0 24 24"
                                width="1.2em"
                                height="1.2em"
                            >
                                <path fill="currentColor" d={path}></path>
                            </svg>
                        ))}
                    </span>
                </a>
            </div>
            <div class="animate leading-relaxed text-[var(--site-color-text-muted)] sm:text-right">
                <a href="/changelog" class="font-bold underline">Changelog</a>
                {" · "}
                <a href="/rss.xml" class="font-bold underline">RSS</a>
            </div>
        </div>
    </Container>
</footer>
