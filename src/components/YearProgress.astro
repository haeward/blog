---
const now = new Date();
const year = now.getFullYear();
const startOfYear = new Date(year, 0, 1);
const endOfYear = new Date(year + 1, 0, 1);
const totalDays = (endOfYear.getTime() - startOfYear.getTime()) / (1000 * 60 * 60 * 24);
const passedDays = Math.round((now.getTime() - startOfYear.getTime()) / (1000 * 60 * 60 * 24));
const progress = (passedDays / totalDays) * 100;

const progressPercentage = progress.toFixed(2);

// Create 20 squares for the progress bar
const totalSquares = 20;
const filledSquares = (progress / 100) * totalSquares;
---

<div class="animate mb-2">
    <div
        class="flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-[#706c64] dark:text-[#9d968b] sm:text-sm"
    >
        <span class="font-mono shrink-0">{year}:</span>
        <div class="flex flex-wrap gap-1">
            {Array.from({ length: totalSquares }, (_, i) => (
        <div
          class={`h-2.5 w-2.5 border border-stone-500 dark:border-stone-300 sm:h-3 sm:w-3 ${
            i < filledSquares
              ? "bg-stone-600 dark:bg-stone-400"
              : "bg-transparent"
          }`}
        />
      ))}
        </div>
        <span class="font-mono shrink-0">{progressPercentage}%</span>
    </div>
</div>
