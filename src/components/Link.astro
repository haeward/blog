---
import { cn } from "@lib/utils";

type Props = {
    href: string;
    external?: boolean;
    underline?: boolean;
    class?: string;
};

const { href, external, underline = false, class: className, ...rest } = Astro.props;
---

<a
    href={href}
    target={external ? "_blank" : undefined}
    rel={external ? "noopener noreferrer" : undefined}
    data-external={external ? "true" : undefined}
    data-underline={underline ? "true" : undefined}
    class={cn("site-link inline-block", className)}
    {...rest}
>
    <slot />
</a>
