---
interface Props {
  id: string;
  page?: string;
  width?: string;
  height?: string;
}

const { 
  id,
  page = "1",
  width = "100%",
  height = "455"
} = Astro.props;

let src = "//player.bilibili.com/player.html?";
let bvid = "";

if (id) {
  const bvidMatch = id.match(/BV\w+/);
  if (bvidMatch) {
    bvid = bvidMatch[0];
  }
}

src += `bvid=${bvid}&page=${page}&danmaku=0&autoplay=0`;
---

<div class="bilibili-embed">
  <iframe 
    src={src}
    width={width}
    height={height}
    scrolling="no"
    frameborder="no"
    allowfullscreen="true"
    loading="lazy"
  ></iframe>
</div>

<style>
  .bilibili-embed {
    position: relative;
    width: 100%;
  }
  
  .bilibili-embed iframe {
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }
</style>
