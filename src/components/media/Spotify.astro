---
interface Props {
  id: string;
  type?: "track" | "album" | "playlist" | "artist";
  theme?: "0" | "1";
  width?: string;
  height?: string;
}

let { 
  id,
  type = "track",
  theme = "0",
  width = "100%",
  height = "152"
} = Astro.props;

let spotifyId = id;

if (id.includes("spotify.com")) {
  const match = id.match(/spotify\.com\/(track|album|playlist|artist)\/([a-zA-Z0-9]+)/);
  if (match) {
    const extractedType = match[1];
    const extractedId = match[2].split("?")[0];

    spotifyId = extractedId;
    if (extractedType) {
      type = extractedType as "track" | "album" | "playlist" | "artist";
    }
  }
}

const src = `https://open.spotify.com/embed/${type}/${spotifyId}?utm_source=generator&theme=${theme}`;
---

<div class="spotify-embed">
  <iframe
    style="border-radius:12px"
    src={src}
    width={width}
    height={height}
    frameborder="0"
    allowfullscreen=""
    allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
    loading="lazy"
  ></iframe>
</div>

<style>
  .spotify-embed {
    position: relative;
    width: 100%;
    margin: 1.5rem 0;
  }
</style>
