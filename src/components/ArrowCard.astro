---
import type { CollectionEntry } from "astro:content";

type CardVariant = "home" | "archive";

type Props = {
    entry: CollectionEntry<"blog">;
    variant?: CardVariant;
};

const { entry, variant = "archive" } = Astro.props;

const isHome = variant === "home";
const formattedDate = new Intl.DateTimeFormat(
    "en-US",
    isHome
        ? {
              year: "numeric",
              month: "short",
              day: "numeric",
          }
        : {
              month: "short",
              day: "numeric",
          },
).format(entry.data.date);

const cardClasses =
    "group grid grid-cols-[auto_minmax(0,1fr)] items-center gap-x-3 px-2 py-3 transition-colors duration-200 ease-out sm:gap-x-4";
const titleClasses = isHome
    ? "serif-reading-title text-[1.03rem] leading-[1.45] font-semibold text-[#45433f] transition-colors duration-200 group-hover:text-[#292827] dark:text-[#b3ada3] dark:group-hover:text-[#d8d3ca] sm:text-[1.12rem]"
    : "serif-reading-title text-[1.08rem] leading-[1.45] font-semibold text-[#45433f] transition-colors duration-200 group-hover:text-[#292827] dark:text-[#b3ada3] dark:group-hover:text-[#d8d3ca] sm:text-[1.16rem]";
const dateWidthClasses = isHome ? "w-[7.7rem] sm:w-[9rem]" : "w-[5rem] sm:w-[5.6rem]";
const dateClasses = isHome
    ? "text-center text-[0.76rem] font-semibold tracking-[0.04em] text-[#706c64] transition-colors duration-200 group-hover:text-[#45433f] dark:text-[#9d968b] dark:group-hover:text-[#b3ada3] sm:text-[0.84rem]"
    : "text-center text-[0.8rem] font-semibold tracking-[0.04em] text-[#706c64] transition-colors duration-200 group-hover:text-[#45433f] dark:text-[#9d968b] dark:group-hover:text-[#b3ada3] sm:text-[0.88rem]";
---

<a href={`/${entry.collection}/${entry.id}`} class={cardClasses}>
    <time
        class:list={[dateWidthClasses, dateClasses, "whitespace-nowrap"]}
        datetime={entry.data.date.toISOString()}
    >
        {formattedDate}
    </time>
    <div class="min-w-0">
        <div class={titleClasses}>{entry.data.title}</div>
    </div>
</a>
