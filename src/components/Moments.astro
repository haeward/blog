---
type Props = {
    account: string;
    accountId: string;
    domain: string;
    profileUrl: string;
    limit?: number;
};

const { account, accountId, domain, profileUrl, limit = 5 } = Astro.props;
---

<section
    class="animate space-y-5"
    data-moments-root="true"
    data-account={account}
    data-account-id={accountId}
    data-domain={domain}
    data-profile-url={profileUrl}
    data-limit={limit.toString()}
>
    <h2 class="serif-reading-title text-2xl font-bold text-[var(--site-color-text-primary)]">
        Moments
    </h2>

    <p
        class="serif-reading-surface text-sm text-[var(--site-color-text-muted)]"
        data-moments-status="true"
        aria-live="polite"
    >
        Loading latest moments...
    </p>

    <ul
        class="overflow-hidden rounded-lg border border-black/10 divide-y divide-black/10 dark:border-white/10 dark:divide-white/10"
        data-moments-list="true"
        hidden
    ></ul>
</section>

<script>
import "../scripts/moments";
</script>
