---
type Props = {
    title?: string;
    headingLevel?: "h1" | "h2";
    account: string;
    accountId: string;
    domain: string;
    profileUrl: string;
    limit?: number;
};

const {
    title = "Moments",
    headingLevel = "h2",
    account,
    accountId,
    domain,
    profileUrl,
    limit = 5,
} = Astro.props;
const HeadingTag = headingLevel;
const headingClass =
    headingLevel === "h1"
        ? "serif-reading-title text-3xl font-bold tracking-[0.01em] text-[var(--site-color-text-primary)] sm:text-4xl"
        : "serif-reading-title text-2xl font-bold text-[var(--site-color-text-primary)]";
---

<section
    class="animate space-y-5"
    data-moments-root="true"
    data-account={account}
    data-account-id={accountId}
    data-domain={domain}
    data-profile-url={profileUrl}
    data-limit={limit.toString()}
>
    <HeadingTag class={headingClass}>{title}</HeadingTag>

    <p
        class="serif-reading-surface text-sm text-[var(--site-color-text-muted)]"
        data-moments-status="true"
        aria-live="polite"
    >
        Loading latest moments...
    </p>

    <ul
        class="overflow-hidden rounded-lg border border-[var(--site-color-surface-border-strong)] divide-y divide-[var(--site-color-surface-border-strong)]"
        data-moments-list="true"
        hidden
    ></ul>
</section>

<script>
import "../scripts/moments";
</script>
