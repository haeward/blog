---
import MediaPanel from "@components/MediaPanel.astro";
import MediaTabs from "@components/MediaTabs.astro";
import type { ClientMediaItem, MediaManifest, MediaTab, MediaTabKey } from "@lib/media";

interface Props {
    tabs: MediaTab[];
    defaultItems: ClientMediaItem[];
    manifest: MediaManifest;
    defaultTab?: MediaTabKey;
}

const { tabs, defaultItems, manifest, defaultTab = manifest.defaultTab } = Astro.props;
const serializedManifest = JSON.stringify(manifest).replace(/</g, "\\u003c");
---

<div class="space-y-10">
    <div class="animate space-y-2"><MediaTabs tabs={tabs} defaultTab={defaultTab} /></div>

    {tabs.map((tab) => (
        <MediaPanel
            tab={tab}
            defaultTab={defaultTab}
            initialItems={tab.key === defaultTab ? defaultItems : []}
        />
    ))}
</div>

<script id="media-data" type="application/json" is:inline set:html={serializedManifest}></script>

<script>
import "../scripts/media-tabs";
</script>
