---
import MediaCard from "@components/MediaCard.astro";
import type { ClientMediaItem, MediaTab, MediaTabKey } from "@lib/media";

interface Props {
    tab: MediaTab;
    defaultTab: MediaTabKey;
    initialItems: ClientMediaItem[];
}

const { tab, defaultTab, initialItems } = Astro.props;
const isDefault = tab.key === defaultTab;
---

<section
    id={tab.key}
    data-tab-panel={tab.key}
    role="tabpanel"
    aria-labelledby={`media-tab-${tab.key}`}
    class="space-y-4 scroll-mt-24"
    hidden={!isDefault}
>
    <ul class="grid grid-cols-2 gap-4 sm:gap-6 md:grid-cols-3 xl:grid-cols-4" data-media-grid>
        {initialItems.map((item) => (
            <MediaCard item={item} />
        ))}
    </ul>

    <div class="flex justify-center pt-8 text-center" data-media-status-wrapper hidden>
        <div class="space-y-3">
            <p
                class="text-sm text-[var(--site-color-text-muted)] sm:text-base"
                data-media-status-message
            ></p>
            <div class="flex justify-center" data-media-retry-wrapper hidden>
                <button
                    type="button"
                    class="group inline-flex min-h-11 items-center justify-center gap-1.5 rounded-lg px-4 py-2 text-sm font-medium text-[var(--site-color-text-muted)] transition-colors duration-200 hover:text-[var(--site-color-text-neutral-hover)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--site-color-focus-ring)] focus-visible:ring-offset-2 focus-visible:ring-offset-stone-100 dark:focus-visible:ring-offset-stone-900"
                    data-media-retry
                >
                    Retry
                </button>
            </div>
        </div>
    </div>

    <div class="h-1 w-full" data-media-sentinel aria-hidden="true"></div>
</section>
