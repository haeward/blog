---
import type { MarkdownHeading } from "astro";

type Props = {
    headings: MarkdownHeading[];
    variant?: "mobile" | "desktop";
    title?: string;
    lang?: string;
};

const { headings, variant = "desktop", title = "Contents", lang = "en" } = Astro.props;

const tocHeadings = headings.filter(({ depth }) => depth >= 2 && depth <= 4);

if (tocHeadings.length === 0) {
    return null;
}

const listClass = variant === "mobile" ? "blog-toc__list blog-toc__list--mobile" : "blog-toc__list";
const depthClasses = {
    2: "blog-toc__link blog-toc__link--depth-2",
    3: "blog-toc__link blog-toc__link--depth-3",
    4: "blog-toc__link blog-toc__link--depth-4",
} as const;
---

{variant === "mobile" ? (
  <nav class="blog-toc blog-toc--mobile animate xl:hidden serif-reading-surface" data-language-scan="true" data-toc-root="true" data-toc-visible="false" lang={lang} aria-label={title}>
    <div class="blog-toc__body">
      <div class="blog-toc__progress" data-toc-progress="true" style="--blog-toc-progress: 0%;">
        <div class="blog-toc__progress-track" aria-hidden="true">
          <span class="blog-toc__progress-fill" data-toc-progress-fill="true"></span>
        </div>
        <span class="blog-toc__progress-label" data-toc-progress-label="true">0%</span>
      </div>
      <ul class={listClass}>
        {tocHeadings.map((heading) => (
          <li>
            <a
              href={`#${heading.slug}`}
              class={depthClasses[heading.depth as 2 | 3 | 4]}
              data-toc-link="true"
              data-slug={heading.slug}
              data-active="false"
            >
              <span class="blog-toc__line" aria-hidden="true"></span>
              <span class="blog-toc__label">{heading.text}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
) : (
  <aside class="blog-toc blog-toc--desktop animate hidden xl:block serif-reading-surface" data-language-scan="true" data-toc-root="true" data-toc-visible="false" lang={lang} aria-label={title}>
    <nav class="blog-toc__body">
      <div class="blog-toc__progress" data-toc-progress="true" style="--blog-toc-progress: 0%;">
        <div class="blog-toc__progress-track" aria-hidden="true">
          <span class="blog-toc__progress-fill" data-toc-progress-fill="true"></span>
        </div>
        <span class="blog-toc__progress-label" data-toc-progress-label="true">0%</span>
      </div>
      <ul class={listClass}>
        {tocHeadings.map((heading) => (
          <li>
            <a
              href={`#${heading.slug}`}
              class={depthClasses[heading.depth as 2 | 3 | 4]}
              data-toc-link="true"
              data-slug={heading.slug}
              data-active="false"
            >
              <span class="blog-toc__line" aria-hidden="true"></span>
              <span class="blog-toc__label">{heading.text}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </aside>
)}
