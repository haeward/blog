---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { SITE, SOCIALS } from "@consts";

interface Props {
    title: string;
    description: string;
    ogImage?: string;
    ogImageAlt?: string;
    ogImageWidth?: number;
    ogImageHeight?: number;
    ogImageType?: string;
    ogType?: "website" | "article";
    publishedTime?: string | Date;
    locale?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const {
    title,
    description,
    ogImage,
    ogImageAlt = `${title} preview image`,
    ogImageWidth = 1200,
    ogImageHeight = 630,
    ogImageType = "image/png",
    ogType = "website",
    publishedTime,
    locale = "en_US",
} = Astro.props;
const ogImageURL = ogImage ? new URL(ogImage, Astro.site) : undefined;
const ogImageWidthContent = String(ogImageWidth);
const ogImageHeightContent = String(ogImageHeight);
const publishedTimeContent =
    publishedTime instanceof Date ? publishedTime.toISOString() : publishedTime;
const twitterSite = getTwitterSite();

function getTwitterSite(): string | undefined {
    const twitter = SOCIALS.find((social) => social.NAME === "Twitter" && social.ENABLE !== false);
    if (!twitter) return undefined;

    try {
        const username = new URL(twitter.HREF).pathname.split("/").filter(Boolean)[0];
        return username ? `@${username}` : undefined;
    } catch {
        return undefined;
    }
}
---

<!-- Global Metadata -->
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="referrer" content="no-referrer">
<link rel="icon" type="image/png" sizes="512x512" href="/assets/images/site/favicon.png">
<meta name="generator" content={Astro.generator}>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL}>

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title}>
<meta name="description" content={description}>

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType}>
<meta property="og:url" content={canonicalURL}>
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:site_name" content={SITE.NAME}>
<meta property="og:locale" content={locale}>
{ogImageURL && (
        <>
            <meta property="og:image" content={ogImageURL} />
            <meta property="og:image:width" content={ogImageWidthContent} />
            <meta property="og:image:height" content={ogImageHeightContent} />
            <meta property="og:image:type" content={ogImageType} />
            <meta property="og:image:alt" content={ogImageAlt} />
        </>
    )}
{publishedTimeContent && <meta property="article:published_time" content={publishedTimeContent} />}

<!-- Twitter -->
<meta name="twitter:card" content={ogImageURL ? "summary_large_image" : "summary"}>
<meta name="twitter:url" content={canonicalURL}>
{twitterSite && <meta name="twitter:site" content={twitterSite} />}
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
{ogImageURL && <meta name="twitter:image" content={ogImageURL} />}
{ogImageURL && <meta name="twitter:image:alt" content={ogImageAlt} />}

<!-- RSS Link -->
<link
    rel="alternate"
    type="application/rss+xml"
    title={SITE.NAME}
    href={new URL("rss.xml", Astro.site)}
>

<ClientRouter />

<script is:inline>
const getStoredTheme = () => {
    const userTheme = localStorage.getItem("theme");
    return userTheme === "light" || userTheme === "dark" ? userTheme : "system";
};
const resolveTheme = (theme, systemPrefersDark) => {
    if (theme === "dark") return true;
    if (theme === "light") return false;
    return systemPrefersDark;
};
const theme = getStoredTheme();
const dark = resolveTheme(theme, window.matchMedia("(prefers-color-scheme: dark)").matches);
document.documentElement.dataset.themeMode = theme;
document.documentElement.classList.toggle("dark", dark);
</script>

<script>
import "../scripts/site";
</script>
