---
import type { MediaTab, MediaTabKey } from "@lib/media";

interface Props {
    tabs: MediaTab[];
    defaultTab: MediaTabKey;
}

const { tabs, defaultTab } = Astro.props;
---

<nav
    id="media-tabs"
    class="flex flex-wrap gap-5 text-sm justify-start"
    role="tablist"
    aria-label="Media categories"
>
    {tabs.map((tab) => (
        <button
            type="button"
            id={`media-tab-${tab.key}`}
            role="tab"
            aria-controls={tab.key}
            aria-selected={tab.key === defaultTab ? "true" : "false"}
            data-tab={tab.key}
            data-active={tab.key === defaultTab ? "true" : "false"}
            class="group px-0 py-1 text-base text-[var(--site-color-text-muted)] hover:text-[var(--site-color-text-neutral-hover)] transition-colors border-b border-transparent data-[active=true]:border-black/60 data-[active=true]:text-[var(--site-color-text-primary)] data-[active=true]:dark:border-white/60"
        >
            {tab.label} <span class="text-[var(--site-color-text-muted)]">({tab.count})</span>
        </button>
    ))}
</nav>
